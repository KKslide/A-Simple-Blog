# 服务
PORT=8088
NODE_ENV=development

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASS=你的密码
MYSQL_DATABASE=myblog

# Session（生产环境请改为足够长的随机字符串）
SESSION_SECRET=请改为足够长的随机字符串

# 七牛云
QINIU_ACCESS_KEY=你的AccessKey
QINIU_SECRET_KEY=你的SecretKey
QINIU_BUCKET=你的空间名
QINIU_IMAGE_URL=http://你的域名/
